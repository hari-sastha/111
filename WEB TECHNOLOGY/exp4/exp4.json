{
  "WEB EXP4 - app.py": {
    "prefix": "web-exp4-app-py",
    "body": [
      "from __future__ import annotations",
      "",
      "from pathlib import Path",
      "import sqlite3",
      "",
      "from flask import Flask, render_template_string, request, redirect, session, url_for",
      "from werkzeug.security import generate_password_hash, check_password_hash",
      "",
      "",
      "app = Flask(__name__)",
      "app.secret_key = 'secret123'  # Change in real projects",
      "",
      "DB_PATH = Path(__file__).resolve().parent / 'bank.db'",
      "",
      "",
      "def get_conn() -> sqlite3.Connection:",
      "    return sqlite3.connect(DB_PATH)",
      "",
      "",
      "def init_db() -> None:",
      "    conn = get_conn()",
      "    cur = conn.cursor()",
      "    cur.execute(",
      "        '''CREATE TABLE IF NOT EXISTS users (",
      "            id INTEGER PRIMARY KEY AUTOINCREMENT,",
      "            username TEXT UNIQUE,",
      "            password TEXT,",
      "            balance REAL DEFAULT 0",
      "        )'''",
      "    )",
      "",
      "    # Sample users (idempotent)",
      "    sample_users = [",
      "        ('USER1', generate_password_hash('1234'), 1000),",
      "        ('USER2', generate_password_hash('1234'), 500),",
      "    ]",
      "    for username, password_hash, balance in sample_users:",
      "        cur.execute(",
      "            \"INSERT OR IGNORE INTO users (username, password, balance) VALUES (?, ?, ?)\",",
      "            (username, password_hash, balance),",
      "        )",
      "",
      "    conn.commit()",
      "    conn.close()",
      "",
      "",
      "LOGIN_TEMPLATE = '''",
      "<style>",
      "    body{font-family:Arial;background:linear-gradient(135deg,#74ebd5,#ACB6E5);display:flex;justify-content:center;align-items:center;height:100vh;}",
      "    .card{background:white;padding:30px;border-radius:15px;box-shadow:0 8px 20px rgba(0,0,0,0.2);width:340px;text-align:center;}",
      "    input{width:90%;padding:10px;margin:10px 0;border:1px solid #ccc;border-radius:8px;}",
      "    button{background:#4CAF50;color:white;padding:10px 20px;border:none;border-radius:8px;cursor:pointer;}",
      "    button:hover{background:#45a049;}",
      "    .hint{margin-top:10px;font-size:12px;color:#374151;}",
      "    .error{margin-top:10px;font-size:13px;color:#b91c1c;font-weight:700;}",
      "</style>",
      "<div class=\"card\">",
      "    <h2>🏦 Bank Login</h2>",
      "    <form method=\"post\">",
      "        <input name=\"username\" placeholder=\"Username\" autocomplete=\"username\" required><br>",
      "        <input type=\"password\" name=\"password\" placeholder=\"Password\" autocomplete=\"current-password\" required><br>",
      "        <button type=\"submit\">Login</button>",
      "    </form>",
      "    <div class=\"hint\">Sample users: <b>USER1</b> / <b>1234</b> and <b>USER2</b> / <b>1234</b></div>",
      "    {% if error %}<div class=\"error\">{{ error }}</div>{% endif %}",
      "</div>",
      "'''",
      "",
      "",
      "DASHBOARD_TEMPLATE = '''",
      "<style>",
      "    body{font-family:Arial;background:#f4f6f9;padding:30px;}",
      "    .container{max-width:600px;margin:auto;background:white;padding:30px;border-radius:15px;box-shadow:0 8px 20px rgba(0,0,0,0.15);}",
      "    h2,h3{text-align:center;}",
      "    form{margin:20px 0;}",
      "    input{padding:10px;width:60%;border:1px solid #ccc;border-radius:8px;}",
      "    button{padding:10px 15px;background:#007BFF;color:white;border:none;border-radius:8px;cursor:pointer;}",
      "    button:hover{background:#0056b3;}",
      "    a{display:block;text-align:center;margin-top:20px;color:red;text-decoration:none;font-weight:bold;}",
      "    .msg{margin-top:10px;text-align:center;color:#b91c1c;font-weight:700;}",
      "</style>",
      "<div class=\"container\">",
      "    <h2>Welcome {{ user }}</h2>",
      "    <h3>Balance: ₹{{ balance }}</h3>",
      "",
      "    <form action=\"{{ url_for('deposit') }}\" method=\"post\">",
      "        <label>Deposit:</label><br>",
      "        <input name=\"amount\" type=\"number\" step=\"0.01\" min=\"0\">",
      "        <button type=\"submit\">Deposit</button>",
      "    </form>",
      "",
      "    <form action=\"{{ url_for('withdraw') }}\" method=\"post\">",
      "        <label>Withdraw:</label><br>",
      "        <input name=\"amount\" type=\"number\" step=\"0.01\" min=\"0\">",
      "        <button type=\"submit\">Withdraw</button>",
      "    </form>",
      "",
      "    <form action=\"{{ url_for('transfer') }}\" method=\"post\">",
      "        <label>Transfer To:</label><br>",
      "        <input name=\"to_user\" autocomplete=\"username\"><br><br>",
      "        <label>Amount:</label><br>",
      "        <input name=\"amount\" type=\"number\" step=\"0.01\" min=\"0\">",
      "        <button type=\"submit\">Transfer</button>",
      "    </form>",
      "",
      "    <a href=\"{{ url_for('logout') }}\">Logout</a>",
      "    {% if message %}<div class=\"msg\">{{ message }}</div>{% endif %}",
      "</div>",
      "'''",
      "",
      "",
      "def _get_user_row(username: str):",
      "    conn = get_conn()",
      "    cur = conn.cursor()",
      "    cur.execute(",
      "        \"SELECT id, username, password, balance FROM users WHERE username = ? COLLATE NOCASE\",",
      "        (username,),",
      "    )",
      "    row = cur.fetchone()",
      "    conn.close()",
      "    return row",
      "",
      "",
      "def _parse_amount(value: str | None) -> float | None:",
      "    try:",
      "        amount = float(value)",
      "        if amount <= 0:",
      "            return None",
      "        return amount",
      "    except Exception:",
      "        return None",
      "",
      "",
      "@app.route('/', methods=['GET', 'POST'])",
      "def login():",
      "    error = None",
      "    if request.method == 'POST':",
      "        username = (request.form.get('username') or '').strip()",
      "        password = request.form.get('password') or ''",
      "",
      "        if not username or not password:",
      "            error = 'Enter both username and password.'",
      "            return render_template_string(LOGIN_TEMPLATE, error=error)",
      "",
      "        user = _get_user_row(username)",
      "        if user:",
      "            stored_password = user[2] or ''",
      "            valid = False",
      "",
      "            # Normal case: hashed passwords",
      "            if ':' in stored_password:",
      "                valid = check_password_hash(stored_password, password)",
      "            else:",
      "                # Legacy compatibility: plaintext password in DB",
      "                valid = stored_password == password",
      "                if valid:",
      "                    conn = get_conn()",
      "                    cur = conn.cursor()",
      "                    cur.execute(",
      "                        \"UPDATE users SET password=? WHERE id=?\",",
      "                        (generate_password_hash(password), user[0]),",
      "                    )",
      "                    conn.commit()",
      "                    conn.close()",
      "",
      "            if valid:",
      "                session['user'] = user[1]",
      "                return redirect(url_for('dashboard'))",
      "",
      "        error = 'Invalid login. Try sample: USER1 / 1234'",
      "",
      "    return render_template_string(LOGIN_TEMPLATE, error=error)",
      "",
      "",
      "@app.route('/dashboard')",
      "def dashboard():",
      "    if 'user' not in session:",
      "        return redirect(url_for('login'))",
      "",
      "    user = _get_user_row(session['user'])",
      "    if not user:",
      "        session.clear()",
      "        return redirect(url_for('login'))",
      "",
      "    return render_template_string(",
      "        DASHBOARD_TEMPLATE,",
      "        user=user[1],",
      "        balance=user[3],",
      "        message=None,",
      "        url_for=url_for,",
      "    )",
      "",
      "",
      "@app.route('/deposit', methods=['POST'])",
      "def deposit():",
      "    if 'user' not in session:",
      "        return redirect(url_for('login'))",
      "",
      "    amount = _parse_amount(request.form.get('amount'))",
      "    if amount is None:",
      "        return redirect(url_for('dashboard'))",
      "",
      "    conn = get_conn()",
      "    cur = conn.cursor()",
      "    cur.execute(",
      "        \"UPDATE users SET balance = balance + ? WHERE username = ? COLLATE NOCASE\",",
      "        (amount, session['user']),",
      "    )",
      "    conn.commit()",
      "    conn.close()",
      "",
      "    return redirect(url_for('dashboard'))",
      "",
      "",
      "@app.route('/withdraw', methods=['POST'])",
      "def withdraw():",
      "    if 'user' not in session:",
      "        return redirect(url_for('login'))",
      "",
      "    amount = _parse_amount(request.form.get('amount'))",
      "    if amount is None:",
      "        return redirect(url_for('dashboard'))",
      "",
      "    conn = get_conn()",
      "    cur = conn.cursor()",
      "    cur.execute(",
      "        \"SELECT balance FROM users WHERE username = ? COLLATE NOCASE\",",
      "        (session['user'],),",
      "    )",
      "    row = cur.fetchone()",
      "    balance = (row[0] if row else 0) or 0",
      "",
      "    if balance >= amount:",
      "        cur.execute(",
      "            \"UPDATE users SET balance = balance - ? WHERE username = ? COLLATE NOCASE\",",
      "            (amount, session['user']),",
      "        )",
      "        conn.commit()",
      "",
      "    conn.close()",
      "    return redirect(url_for('dashboard'))",
      "",
      "",
      "@app.route('/transfer', methods=['POST'])",
      "def transfer():",
      "    if 'user' not in session:",
      "        return redirect(url_for('login'))",
      "",
      "    to_user = (request.form.get('to_user') or '').strip()",
      "    amount = _parse_amount(request.form.get('amount'))",
      "    if not to_user or amount is None:",
      "        return redirect(url_for('dashboard'))",
      "",
      "    conn = get_conn()",
      "    cur = conn.cursor()",
      "",
      "    cur.execute(",
      "        \"SELECT balance FROM users WHERE username = ? COLLATE NOCASE\",",
      "        (session['user'],),",
      "    )",
      "    row = cur.fetchone()",
      "    balance = (row[0] if row else 0) or 0",
      "",
      "    cur.execute(",
      "        \"SELECT id FROM users WHERE username = ? COLLATE NOCASE\",",
      "        (to_user,),",
      "    )",
      "    receiver = cur.fetchone()",
      "",
      "    if balance >= amount and receiver:",
      "        cur.execute(",
      "            \"UPDATE users SET balance = balance - ? WHERE username = ? COLLATE NOCASE\",",
      "            (amount, session['user']),",
      "        )",
      "        cur.execute(",
      "            \"UPDATE users SET balance = balance + ? WHERE username = ? COLLATE NOCASE\",",
      "            (amount, to_user),",
      "        )",
      "        conn.commit()",
      "",
      "    conn.close()",
      "    return redirect(url_for('dashboard'))",
      "",
      "",
      "@app.route('/logout')",
      "def logout():",
      "    session.clear()",
      "    return redirect(url_for('login'))",
      "",
      "# ---------------- RUN APP ----------------",
      "if __name__ == '__main__':",
      "\tinit_db()",
      "\tapp.run(debug=True)"
    ]
  }
}