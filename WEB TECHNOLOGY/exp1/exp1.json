{
  "WEB EXP1 - index.html": {
    "prefix": "web-exp1-index-html",
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"en\">",
      "<head>",
      "  <meta charset=\"UTF-8\" />",
      "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>",
      "  <title>Sample Portfolio</title>",
      "  <link rel=\"stylesheet\" href=\"portfolio.css\" />",
      "</head>",
      "<body>",
      "  <header class=\"site-header\">",
      "    <div class=\"container header-inner\">",
      "      <div class=\"brand\">",
      "        <h1>Your Name</h1>",
      "        <p class=\"tagline\">Student • Developer • Problem Solver</p>",
      "      </div>",
      "      <nav class=\"nav\">",
      "        <a href=\"#about\">About</a>",
      "        <a href=\"#skills\">Skills</a>",
      "        <a href=\"#projects\">Projects</a>",
      "        <a href=\"#certificates\">Certificates</a>",
      "        <a href=\"#contact\">Contact</a>",
      "      </nav>",
      "    </div>",
      "  </header>",
      "",
      "  <main>",
      "    <section id=\"about\" class=\"section\">",
      "      <div class=\"container\">",
      "        <div class=\"about-container\">",
      "          <div class=\"about-text\">",
      "            <h2>About</h2>",
      "            <p>",
      "              This is a sample portfolio template for learning web development.",
      "              Replace the text with your own details (name, projects, skills, and links).",
      "            </p>",
      "            <p>",
      "              Focus areas: clean UI, responsive layout, and simple sections that are easy to extend.",
      "            </p>",
      "",
      "            <div class=\"quick-highlights\">",
      "              <div class=\"highlight\">",
      "                <div class=\"highlight-title\">Goal</div>",
      "                <div class=\"highlight-value\">Build real projects</div>",
      "              </div>",
      "              <div class=\"highlight\">",
      "                <div class=\"highlight-title\">Stack</div>",
      "                <div class=\"highlight-value\">HTML • CSS • JS</div>",
      "              </div>",
      "              <div class=\"highlight\">",
      "                <div class=\"highlight-title\">Availability</div>",
      "                <div class=\"highlight-value\">Open to internships</div>",
      "              </div>",
      "            </div>",
      "          </div>",
      "",
      "          <div class=\"about-card\" aria-label=\"Profile card\">",
      "            <div class=\"avatar\" aria-hidden=\"true\">YN</div>",
      "            <div class=\"about-card-title\">Your Name</div>",
      "            <div class=\"about-card-subtitle\">Full Stack Learner</div>",
      "            <div class=\"about-card-meta\">Based in Your City</div>",
      "            <a class=\"primary-cta\" href=\"#projects\">View Projects</a>",
      "          </div>",
      "        </div>",
      "      </div>",
      "    </section>",
      "",
      "    <section id=\"skills\" class=\"section section-alt\">",
      "      <div class=\"container\">",
      "        <h2>Skills</h2>",
      "        <div class=\"chips\">",
      "          <span class=\"chip\">HTML</span>",
      "          <span class=\"chip\">CSS</span>",
      "          <span class=\"chip\">JavaScript</span>",
      "          <span class=\"chip\">Python</span>",
      "          <span class=\"chip\">SQL</span>",
      "          <span class=\"chip\">Git</span>",
      "          <span class=\"chip\">Basics of APIs</span>",
      "        </div>",
      "      </div>",
      "    </section>",
      "",
      "    <section id=\"projects\" class=\"section\">",
      "      <div class=\"container\">",
      "        <div class=\"section-head\">",
      "          <h2>Projects</h2>",
      "          <p class=\"section-subtitle\">A few sample project ideas you can replace with your own.</p>",
      "        </div>",
      "        <div class=\"cards\">",
      "          <article class=\"card\">",
      "            <h3>Task Manager</h3>",
      "            <p>CRUD tasks with a simple UI and local persistence.</p>",
      "            <div class=\"card-tags\">",
      "              <span>HTML</span><span>CSS</span><span>JS</span>",
      "            </div>",
      "          </article>",
      "          <article class=\"card\">",
      "            <h3>Weather Dashboard</h3>",
      "            <p>Search a city and show live weather using an API.</p>",
      "            <div class=\"card-tags\">",
      "              <span>Fetch API</span><span>UI</span><span>JSON</span>",
      "            </div>",
      "          </article>",
      "          <article class=\"card\">",
      "            <h3>Portfolio Template</h3>",
      "            <p>Responsive portfolio with sections and clean typography.</p>",
      "            <div class=\"card-tags\">",
      "              <span>Responsive</span><span>Layout</span><span>Accessibility</span>",
      "            </div>",
      "          </article>",
      "        </div>",
      "      </div>",
      "    </section>",
      "",
      "    <section id=\"certificates\" class=\"section section-alt\">",
      "      <div class=\"container\">",
      "        <div class=\"section-head\">",
      "          <h2>Certificates</h2>",
      "          <p class=\"section-subtitle\">Add your certificates here (optional).</p>",
      "        </div>",
      "        <div class=\"certificates-grid\" role=\"list\">",
      "          <div class=\"certificate-box\" role=\"listitem\">",
      "            <span>Web Basics</span>",
      "            <small>Sample Provider</small>",
      "          </div>",
      "          <div class=\"certificate-box\" role=\"listitem\">",
      "            <span>JavaScript Essentials</span>",
      "            <small>Sample Provider</small>",
      "          </div>",
      "          <div class=\"certificate-box\" role=\"listitem\">",
      "            <span>Database Fundamentals</span>",
      "            <small>Sample Provider</small>",
      "          </div>",
      "        </div>",
      "      </div>",
      "    </section>",
      "",
      "    <section id=\"contact\" class=\"section\">",
      "      <div class=\"container\">",
      "        <div class=\"section-head\">",
      "          <h2>Contact</h2>",
      "          <p class=\"section-subtitle\">Use these placeholders and replace with your own links.</p>",
      "        </div>",
      "",
      "        <div class=\"contact-grid\">",
      "          <div class=\"contact-item\">",
      "            <img src=\"images/mail.jpg\" alt=\"Email\" class=\"icon\">",
      "            <div>",
      "              <div class=\"contact-label\">Email</div>",
      "              <a href=\"mailto:hello@example.com\">hello@example.com</a>",
      "            </div>",
      "          </div>",
      "",
      "          <div class=\"contact-item\">",
      "            <img src=\"images/github.png\" alt=\"GitHub\" class=\"icon\">",
      "            <div>",
      "              <div class=\"contact-label\">GitHub</div>",
      "              <a href=\"https://github.com/your-username\" target=\"_blank\" rel=\"noreferrer\">github.com/your-username</a>",
      "            </div>",
      "          </div>",
      "",
      "          <div class=\"contact-item\">",
      "            <img src=\"images/linkedin.jpg\" alt=\"LinkedIn\" class=\"icon\">",
      "            <div>",
      "              <div class=\"contact-label\">LinkedIn</div>",
      "              <a href=\"https://www.linkedin.com/in/your-profile/\" target=\"_blank\" rel=\"noreferrer\">linkedin.com/in/your-profile</a>",
      "            </div>",
      "          </div>",
      "        </div>",
      "      </div>",
      "    </section>",
      "  </main>",
      "",
      "  <footer class=\"site-footer\">",
      "    <div class=\"container\">",
      "      <p>&copy; 2026 Your Name. All rights reserved.</p>",
      "    </div>",
      "  </footer>",
      "</body>",
      "</html>"
    ]
  },
  "WEB EXP1 - portfolio.css": {
    "prefix": "web-exp1-portfolio-css",
    "body": [
      "* {",
      "  margin: 0;",
      "  padding: 0;",
      "  box-sizing: border-box;",
      "}",
      "",
      "body {",
      "  font-family: Arial, sans-serif;",
      "  line-height: 1.6;",
      "}",
      "",
      "header {",
      "  background: black;",
      "  color:white;",
      "  padding: 1rem 2rem;",
      "  display: flex;",
      "  justify-content: space-between;",
      "  align-items: center;",
      "  flex-wrap: wrap;",
      "  position: relative;",
      "}",
      "",
      "header nav a {",
      "  color: white;",
      "  margin-left: 1rem;",
      "  text-decoration: none;",
      "}",
      "",
      "section {",
      "  padding: 2rem;",
      "}",
      "",
      "footer {",
      "  text-align: center;",
      "  padding: 1rem;",
      "  background: #333;",
      "  color: white;",
      "  margin-top: 2rem;",
      "}",
      "",
      "/* Responsive Design */",
      "@media (max-width: 600px) {",
      "  header {",
      "    flex-direction: column;",
      "    align-items: flex-start;",
      "  }",
      "",
      "  header nav {",
      "    margin-top: 1rem;",
      "  }",
      "  .main-sections {",
      "    flex-direction: column;",
      "    gap: 1rem;",
      "  }",
      "  .certificates-grid {",
      "    flex-direction: column;",
      "    gap: 1rem;",
      "  }",
      "  .skills-list {",
      "    flex-direction: column;",
      "    gap: 1rem;",
      "  }",
      "  .projects-container {",
      "    gap: 1rem;",
      "  }",
      "}",
      "",
      ".about-container {",
      "  display: flex;",
      "  align-items: center;",
      "  justify-content: space-between;",
      "  gap: 40px;",
      "  flex-wrap: wrap;",
      "  padding: 2.5rem 2rem;",
      "  margin-bottom: 2rem;",
      "}",
      "",
      ".about-text {",
      "  flex: 2;",
      "  min-width: 250px;",
      "  color: #222;",
      "}",
      "",
      ".about-image {",
      "  flex: 1;",
      "  display: flex;",
      "  justify-content: flex-end;",
      "}",
      "",
      ".profile-photo {",
      "  width: 200px;",
      "  height: 200px;",
      "  border-radius: 50%;",
      "  object-fit: cover;",
      "  object-position: center;",
      "  display: block;",
      "  margin: 0 auto;",
      "  border: 4px solid #a259f7;",
      "}",
      "",
      ".more-about-btn {",
      "  display: inline-flex;",
      "  align-items: center;",
      "  gap: 0.5rem;",
      "  margin-top: 1.5rem;",
      "  background: #a259f7;",
      "  color: #fff;",
      "  padding: 0.7rem 1.8rem;",
      "  border-radius: 50px;",
      "  text-decoration: none;",
      "  font-weight: bold;",
      "  font-size: 0.97rem;",
      "  letter-spacing: 0.5px;",
      "  box-shadow: 0 4px 15px rgba(162, 89, 247, 0.30);",
      "  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;",
      "}",
      " ",
      "",
      ".icon {",
      "  width: 20px;",
      "  height: 20px;",
      "  vertical-align: middle;",
      "  margin-right: 8px;",
      "}",
      "",
      ".about-text h2 {",
      "  font-size: 2.5rem;",
      "  font-weight: bold;",
      "  margin-bottom: 1rem;",
      "  color: #222;",
      "}",
      "",
      ".skills-container {",
      "  background: none;",
      "  border-radius: 0;",
      "  box-shadow: none;",
      "  padding: 0;",
      "  margin-bottom: 2rem;",
      "  color: #222;",
      "  max-width: 100%;",
      "  margin-left: 0;",
      "  margin-right: 0;",
      "  text-align: left;",
      "}",
      "",
      ".skills-list {",
      "  list-style: none;",
      "  padding: 0;",
      "  margin: 1rem 0 0 0;",
      "  display: flex;",
      "  flex-wrap: wrap;",
      "  gap: 1.5rem;",
      "}",
      "",
      ".skills-list li {",
      "  margin-bottom: 0;",
      "}",
      "",
      ".skills-list a {",
      "  display: flex;",
      "  flex-direction: column;",
      "  align-items: center;",
      "  justify-content: center;",
      "  background: #f3f0fa;",
      "  color: #222;",
      "  padding: 1.2rem 1rem;",
      "  border-radius: 12px;",
      "  font-weight: bold;",
      "  letter-spacing: 1px;",
      "  text-decoration: none;",
      "  box-shadow: 0 2px 8px rgba(162, 89, 247, 0.10);",
      "  transition: background 0.2s, color 0.2s, transform 0.2s;",
      "  min-width: 180px;",
      "  max-width: 220px;",
      "  text-align: center;",
      "}",
      "",
      ".skills-list a:hover {",
      "  background: #a259f7;",
      "  color: #fff;",
      "  transform: translateY(-4px) scale(1.03);",
      "}",
      "",
      ".main-sections {",
      "  display: flex;",
      "  gap: 2rem;",
      "  align-items: flex-start;",
      "  justify-content: center;",
      "  margin-bottom: 2rem;",
      "}",
      "",
      ".projects-container {",
      "  display: flex;",
      "  flex-direction: column;",
      "  gap: 1.5rem;",
      "  width: 100%;",
      "}",
      "",
      ".project {",
      "  background: #f3f0fa;",
      "  color: #222;",
      "  border-radius: 12px;",
      "  padding: 1.2rem 1rem;",
      "  box-shadow: 0 2px 8px rgba(162, 89, 247, 0.10);",
      "  transition: background 0.2s, color 0.2s, transform 0.2s;",
      "  font-weight: bold;",
      "  min-width: 180px;",
      "  max-width: 220px;",
      "  text-align: center;",
      "  margin-bottom: 0;",
      "  display: flex;",
      "  flex-direction: column;",
      "  align-items: center;",
      "}",
      "",
      ".project:hover {",
      "  background: #a259f7;",
      "  color: #fff;",
      "  transform: translateY(-4px) scale(1.03);",
      "}",
      "",
      ".project h3 {",
      "  margin-bottom: 0.5rem;",
      "  font-size: 1.2rem;",
      "  font-weight: bold;",
      "}",
      "",
      ".project p {",
      "  font-weight: normal;",
      "  font-size: 0.95rem;",
      "  margin: 0;",
      "  color: #555;",
      "}",
      "",
      ".project:hover p {",
      "  color: #fff;",
      "}",
      "",
      "/* Certificates Section */",
      ".certificates-grid {",
      "  display: flex;",
      "  gap: 1.5rem;",
      "  flex-wrap: wrap;",
      "  margin: 1.5rem 0 2rem 0;",
      "  justify-content: flex-start;",
      "}",
      "",
      ".certificate-box {",
      "  flex: 1 1 180px;",
      "  min-width: 180px;",
      "  max-width: 220px;",
      "  background: #f3f0fa;",
      "  color: #222;",
      "  border-radius: 12px;",
      "  padding: 1.2rem 1rem;",
      "  text-align: center;",
      "  text-decoration: none;",
      "  box-shadow: 0 2px 8px rgba(162, 89, 247, 0.10);",
      "  transition: background 0.2s, transform 0.2s;",
      "  font-weight: bold;",
      "  display: flex;",
      "  flex-direction: column;",
      "  align-items: center;",
      "}",
      "",
      ".certificate-box:hover {",
      "  background: #a259f7;",
      "  color: #fff;",
      "  transform: translateY(-4px) scale(1.03);",
      "}",
      "",
      ".certificate-box small {",
      "  font-weight: normal;",
      "  font-size: 0.95rem;",
      "  margin-top: 0.5rem;",
      "  color: #555;",
      "}",
      "",
      ".certificate-box:hover small {",
      "  color: #fff;",
      "}",
      "",
      "/* === Sample Portfolio Theme Override (generic, no personal data) === */",
      "",
      ":root {",
      "  --bg: #0b1220;",
      "  --bg2: #0b1020;",
      "  --surface: rgba(255, 255, 255, 0.08);",
      "  --surface2: rgba(255, 255, 255, 0.06);",
      "  --text: rgba(255, 255, 255, 0.92);",
      "  --muted: rgba(255, 255, 255, 0.72);",
      "  --border: rgba(255, 255, 255, 0.14);",
      "  --shadow: 0 18px 44px rgba(0, 0, 0, 0.45);",
      "  --radius: 16px;",
      "}",
      "",
      "body {",
      "  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;",
      "  color: var(--text);",
      "  background: radial-gradient(1200px 600px at 20% 10%, rgba(162, 89, 247, 0.30), transparent 60%),",
      "    radial-gradient(1200px 600px at 80% 20%, rgba(64, 214, 255, 0.22), transparent 60%),",
      "    linear-gradient(180deg, var(--bg), var(--bg2));",
      "}",
      "",
      "a {",
      "  color: inherit;",
      "}",
      "",
      ".container {",
      "  max-width: 1100px;",
      "  margin: 0 auto;",
      "  padding: 0 20px;",
      "}",
      "",
      ".site-header {",
      "  position: sticky;",
      "  top: 0;",
      "  background: rgba(11, 18, 32, 0.75);",
      "  -webkit-backdrop-filter: blur(10px);",
      "  backdrop-filter: blur(10px);",
      "  border-bottom: 1px solid var(--border);",
      "  z-index: 10;",
      "}",
      "",
      ".header-inner {",
      "  display: flex;",
      "  align-items: center;",
      "  justify-content: space-between;",
      "  gap: 16px;",
      "  padding: 18px 0;",
      "}",
      "",
      ".brand h1 {",
      "  font-size: 1.25rem;",
      "  letter-spacing: 0.4px;",
      "}",
      "",
      ".tagline {",
      "  margin-top: 4px;",
      "  color: var(--muted);",
      "  font-size: 0.95rem;",
      "}",
      "",
      ".nav {",
      "  display: flex;",
      "  flex-wrap: wrap;",
      "  gap: 12px;",
      "}",
      "",
      ".nav a {",
      "  text-decoration: none;",
      "  padding: 8px 12px;",
      "  border: 1px solid transparent;",
      "  border-radius: 999px;",
      "  color: var(--text);",
      "}",
      "",
      ".nav a:hover {",
      "  border-color: var(--border);",
      "  background: rgba(255, 255, 255, 0.06);",
      "}",
      "",
      ".section {",
      "  padding: 48px 0;",
      "}",
      "",
      ".section-alt {",
      "  background: rgba(255, 255, 255, 0.03);",
      "  border-top: 1px solid rgba(255, 255, 255, 0.06);",
      "  border-bottom: 1px solid rgba(255, 255, 255, 0.06);",
      "}",
      "",
      ".section h2 {",
      "  font-size: 1.4rem;",
      "  margin-bottom: 14px;",
      "}",
      "",
      ".section-head {",
      "  display: flex;",
      "  align-items: baseline;",
      "  justify-content: space-between;",
      "  gap: 12px;",
      "  flex-wrap: wrap;",
      "  margin-bottom: 18px;",
      "}",
      "",
      ".section-subtitle {",
      "  margin: 0;",
      "  color: var(--muted);",
      "}",
      "",
      ".about-container {",
      "  display: grid;",
      "  grid-template-columns: 1.6fr 1fr;",
      "  gap: 22px;",
      "  align-items: start;",
      "  padding: 0;",
      "  margin: 0;",
      "}",
      "",
      ".about-text {",
      "  color: var(--text);",
      "}",
      "",
      ".about-text p {",
      "  color: var(--muted);",
      "  margin: 10px 0;",
      "}",
      "",
      ".quick-highlights {",
      "  display: grid;",
      "  grid-template-columns: repeat(3, minmax(0, 1fr));",
      "  gap: 12px;",
      "  margin-top: 16px;",
      "}",
      "",
      ".highlight {",
      "  border: 1px solid var(--border);",
      "  background: rgba(255, 255, 255, 0.06);",
      "  border-radius: var(--radius);",
      "  padding: 14px;",
      "}",
      "",
      ".highlight-title {",
      "  color: var(--muted);",
      "  font-size: 0.85rem;",
      "}",
      "",
      ".highlight-value {",
      "  margin-top: 6px;",
      "  font-weight: 700;",
      "}",
      "",
      ".about-card {",
      "  border: 1px solid var(--border);",
      "  background: linear-gradient(180deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0.06));",
      "  border-radius: calc(var(--radius) + 2px);",
      "  padding: 18px;",
      "  box-shadow: var(--shadow);",
      "  display: flex;",
      "  flex-direction: column;",
      "  align-items: flex-start;",
      "  gap: 8px;",
      "}",
      "",
      ".avatar {",
      "  width: 56px;",
      "  height: 56px;",
      "  border-radius: 16px;",
      "  display: grid;",
      "  place-items: center;",
      "  font-weight: 800;",
      "  letter-spacing: 1px;",
      "  background: radial-gradient(100% 100% at 20% 10%, rgba(162, 89, 247, 0.95), rgba(64, 214, 255, 0.55));",
      "  color: rgba(255, 255, 255, 0.95);",
      "}",
      "",
      ".about-card-title {",
      "  font-weight: 800;",
      "  font-size: 1.05rem;",
      "}",
      "",
      ".about-card-subtitle,",
      ".about-card-meta {",
      "  color: var(--muted);",
      "}",
      "",
      ".primary-cta {",
      "  display: inline-flex;",
      "  align-items: center;",
      "  justify-content: center;",
      "  margin-top: 8px;",
      "  text-decoration: none;",
      "  padding: 10px 12px;",
      "  border-radius: 12px;",
      "  border: 1px solid var(--border);",
      "  background: rgba(255, 255, 255, 0.08);",
      "  font-weight: 700;",
      "}",
      "",
      ".primary-cta:hover {",
      "  background: rgba(255, 255, 255, 0.12);",
      "}",
      "",
      ".chips {",
      "  display: flex;",
      "  flex-wrap: wrap;",
      "  gap: 10px;",
      "}",
      "",
      ".chip {",
      "  border: 1px solid var(--border);",
      "  background: rgba(255, 255, 255, 0.06);",
      "  padding: 10px 12px;",
      "  border-radius: 999px;",
      "  color: var(--text);",
      "  font-weight: 650;",
      "}",
      "",
      ".cards {",
      "  display: grid;",
      "  grid-template-columns: repeat(3, minmax(0, 1fr));",
      "  gap: 14px;",
      "}",
      "",
      ".card {",
      "  border: 1px solid var(--border);",
      "  background: rgba(255, 255, 255, 0.06);",
      "  border-radius: var(--radius);",
      "  padding: 16px;",
      "}",
      "",
      ".card h3 {",
      "  margin-bottom: 8px;",
      "}",
      "",
      ".card p {",
      "  margin: 0;",
      "  color: var(--muted);",
      "}",
      "",
      ".card-tags {",
      "  display: flex;",
      "  flex-wrap: wrap;",
      "  gap: 8px;",
      "  margin-top: 12px;",
      "}",
      "",
      ".card-tags span {",
      "  border: 1px solid rgba(255, 255, 255, 0.12);",
      "  background: rgba(255, 255, 255, 0.05);",
      "  padding: 6px 10px;",
      "  border-radius: 999px;",
      "  color: var(--muted);",
      "  font-size: 0.85rem;",
      "}",
      "",
      ".certificates-grid {",
      "  display: grid;",
      "  grid-template-columns: repeat(3, minmax(0, 1fr));",
      "  gap: 14px;",
      "  margin: 0;",
      "}",
      "",
      ".certificate-box {",
      "  border: 1px solid var(--border);",
      "  background: rgba(255, 255, 255, 0.06);",
      "  border-radius: var(--radius);",
      "  padding: 16px;",
      "  text-decoration: none;",
      "  box-shadow: none;",
      "}",
      "",
      ".certificate-box span {",
      "  font-weight: 800;",
      "  color: var(--text);",
      "}",
      "",
      ".certificate-box small {",
      "  color: var(--muted);",
      "  margin-top: 8px;",
      "}",
      "",
      ".certificate-box:hover {",
      "  transform: none;",
      "  background: rgba(255, 255, 255, 0.08);",
      "}",
      "",
      ".contact-grid {",
      "  display: grid;",
      "  grid-template-columns: repeat(3, minmax(0, 1fr));",
      "  gap: 14px;",
      "}",
      "",
      ".contact-item {",
      "  display: flex;",
      "  gap: 12px;",
      "  align-items: center;",
      "  border: 1px solid var(--border);",
      "  background: rgba(255, 255, 255, 0.06);",
      "  border-radius: var(--radius);",
      "  padding: 14px;",
      "}",
      "",
      ".contact-label {",
      "  color: var(--muted);",
      "  font-size: 0.85rem;",
      "  margin-bottom: 4px;",
      "}",
      "",
      ".contact-item a {",
      "  color: var(--text);",
      "  text-decoration: none;",
      "  border-bottom: 1px dashed rgba(255, 255, 255, 0.22);",
      "}",
      "",
      ".contact-item a:hover {",
      "  border-bottom-color: rgba(255, 255, 255, 0.55);",
      "}",
      "",
      ".site-footer {",
      "  padding: 22px 0;",
      "  border-top: 1px solid rgba(255, 255, 255, 0.10);",
      "  color: var(--muted);",
      "  background: rgba(0, 0, 0, 0.18);",
      "}",
      "",
      ".site-footer p {",
      "  margin: 0;",
      "}",
      "",
      "/* Responsive */",
      "@media (max-width: 900px) {",
      "  .about-container {",
      "    grid-template-columns: 1fr;",
      "  }",
      "  .cards {",
      "    grid-template-columns: 1fr;",
      "  }",
      "  .certificates-grid {",
      "    grid-template-columns: 1fr;",
      "  }",
      "  .contact-grid {",
      "    grid-template-columns: 1fr;",
      "  }",
      "  .quick-highlights {",
      "    grid-template-columns: 1fr;",
      "  }",
      "}"
    ]
  }
}