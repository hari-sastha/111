      "class ChessGame:",
      "    def __init__(self):",
      "        self.board = [",
      "            ['r','n','b','q','k','b','n','r'],",
      "            ['p','p','p','p','p','p','p','p'],",
      "            [' ',' ',' ',' ',' ',' ',' ',' '],",
      "            [' ',' ',' ',' ',' ',' ',' ',' '],",
      "            [' ',' ',' ',' ',' ',' ',' ',' '],",
      "            [' ',' ',' ',' ',' ',' ',' ',' '],",
      "            ['P','P','P','P','P','P','P','P'],",
      "            ['R','N','B','Q','K','B','N','R']",
      "        ]",
      "        self.white_turn = True",
      "",
      "    def print_board(self):",
      "        for row in self.board:",
      "            print(' '.join(row))",
      "        print()",
      "",
      "    def get_pawn_moves(self, r, c):",
      "        moves = []",
      "        d = -1 if self.board[r][c].isupper() else 1",
      "        if self.board[r+d][c] == ' ':",
      "            moves.append((r+d, c))",
      "        return moves",
      "",
      "    def is_valid(self, r, c, nr, nc):",
      "        if not (0 <= nr < 8 and 0 <= nc < 8):",
      "            return False",
      "        if self.board[nr][nc].isupper() == self.white_turn:",
      "            return False",
      "        return (nr, nc) in self.get_pawn_moves(r, c)",
      "",
      "    def move(self, r, c, nr, nc):",
      "        self.board[nr][nc] = self.board[r][c]",
      "        self.board[r][c] = ' '",
      "        self.white_turn = not self.white_turn",
      "",
      "    def play(self):",
      "        while True:",
      "            self.print_board()",
      "            print('White' if self.white_turn else 'Black', 'turn')",
      "            s = input('From (e.g., a2): ')",
      "            d = input('To (e.g., a3): ')",
      "",
      "            sc, sr = ord(s[0]) - 97, 8 - int(s[1])",
      "            dc, dr = ord(d[0]) - 97, 8 - int(d[1])",
      "",
      "            if self.is_valid(sr, sc, dr, dc):",
      "                self.move(sr, sc, dr, dc)",
      "            else:",
      "                print('Invalid move!')",
      "",
      "",
      "game = ChessGame()",
      "game.play()"
