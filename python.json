  "Experiment 5": {
    "prefix": "exp5",
    "body": [
      "class SegmentTree:",
      "    def __init__(self, arr):",
      "        self.n = len(arr)",
      "        self.tree = [0] * (4 * self.n)",
      "        self.build(arr, 0, self.n - 1, 0)",
      "",
      "    def build(self, arr, s, e, i):",
      "        if s == e:",
      "            self.tree[i] = arr[s]",
      "            return",
      "        m = (s + e) // 2",
      "        self.build(arr, s, m, 2*i+1)",
      "        self.build(arr, m+1, e, 2*i+2)",
      "        self.tree[i] = self.tree[2*i+1] + self.tree[2*i+2]",
      "",
      "    def query(self, qs, qe, s, e, i):",
      "        if qs <= s and qe >= e: return self.tree[i]",
      "        if qe < s or qs > e: return 0",
      "        m = (s + e) // 2",
      "        return self.query(qs, qe, s, m, 2*i+1) + \\",
      "               self.query(qs, qe, m+1, e, 2*i+2)",
      "",
      "    def update(self, idx, val, s, e, i):",
      "        if s == e:",
      "            self.tree[i] = val",
      "            return",
      "        m = (s + e) // 2",
      "        if idx <= m:",
      "            self.update(idx, val, s, m, 2*i+1)",
      "        else:",
      "            self.update(idx, val, m+1, e, 2*i+2)",
      "        self.tree[i] = self.tree[2*i+1] + self.tree[2*i+2]",
      "",
      "",
      "",
      "arr = list(map(int, input('Array: ').split()))",
      "st = SegmentTree(arr)",
      "",
      "l, r = map(int, input('Query range: ').split())",
      "print('Sum:', st.query(l, r, 0, len(arr)-1, 0))",
      "",
      "i, v = map(int, input('Update (index value): ').split())",
      "st.update(i, v, 0, len(arr)-1, 0)",
      "",
      "print('Updated Sum:', st.query(l, r, 0, len(arr)-1, 0))"
    ]
  },
  "Experiment 6": {
    "prefix": "exp6",
    "body": [
      "import math",
      "",
      "class QuadTreeNode:",
      "    def __init__(self, boundary):",
      "        self.boundary = boundary  # (x, y, w, h)",
      "        self.cities = []",
      "        self.children = [None, None, None, None]",
      "",
      "",
      "class QuadTree:",
      "    def __init__(self, boundary, capacity):",
      "        self.root = QuadTreeNode(boundary)",
      "        self.capacity = capacity",
      "",
      "    def insert(self, city):",
      "        self._insert(self.root, city)",
      "",
      "    def _insert(self, node, city):",
      "        if not self._contains(node.boundary, city):",
      "            return",
      "",
      "        if len(node.cities) < self.capacity and node.children[0] is None:",
      "            node.cities.append(city)",
      "        else:",
      "            if node.children[0] is None:",
      "                self._subdivide(node)",
      "            for child in node.children:",
      "                self._insert(child, city)",
      "",
      "    def _subdivide(self, node):",
      "        x, y, w, h = node.boundary",
      "        hw, hh = w / 2, h / 2",
      "",
      "        node.children[0] = QuadTreeNode((x, y, hw, hh))",
      "        node.children[1] = QuadTreeNode((x + hw, y, hw, hh))",
      "        node.children[2] = QuadTreeNode((x, y + hh, hw, hh))",
      "        node.children[3] = QuadTreeNode((x + hw, y + hh, hw, hh))",
      "",
      "        ",
      "        for city in node.cities:",
      "            for child in node.children:",
      "                if self._contains(child.boundary, city):",
      "                    self._insert(child, city)",
      "",
      "        node.cities = []",
      "",
      "    def _contains(self, boundary, city):",
      "        x, y, w, h = boundary",
      "        return x <= city[0] < x + w and y <= city[1] < y + h",
      "",
      "   ",
      "    def nearest(self, point):",
      "        best_city, _ = self._nearest(self.root, point, None, float('inf'))",
      "        return best_city",
      "",
      "    def _nearest(self, node, point, best_city, best_dist):",
      "        if node is None:",
      "            return best_city, best_dist",
      "",
      "        ",
      "        for city in node.cities:",
      "            d = math.dist(point, city)",
      "            if d < best_dist:",
      "                best_city = city",
      "                best_dist = d",
      "",
      "        ",
      "        for child in node.children:",
      "            best_city, best_dist = self._nearest(child, point, best_city, best_dist)",
      "",
      "        return best_city, best_dist",
      "",
      "",
      "",
      "qt = QuadTree((0, 0, 100, 100), 2)",
      "",
      "n = int(input('Number of cities: '))",
      "for _ in range(n):",
      "    x, y = map(int, input('Enter city (x y): ').split())",
      "    qt.insert((x, y))",
      "",
      "px, py = map(int, input('Enter query point: ').split())",
      "",
      "result = qt.nearest((px, py))",
      "",
      "if result:",
      "    print('Nearest city:', result)",
      "else:",
      "    print('No cities found.')"
    ]
