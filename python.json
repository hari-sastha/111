 {
  "Experiment 1": {
    "prefix": "exp1",
    "body": [
      "class TrieNode:",
      "    def __init__(self):",
      "        self.children = {}",
      "        self.is_end = False",
      "",
      "",
      "class Trie:",
      "    def __init__(self):",
      "        self.root = TrieNode()",
      "",
      "    ",
      "    def insert(self, word):",
      "        node = self.root",
      "        for char in word:",
      "            if char not in node.children:",
      "                node.children[char] = TrieNode()",
      "            node = node.children[char]",
      "        node.is_end = True",
      "",
      "    ",
      "    def search(self, prefix):",
      "        node = self.root",
      "        for char in prefix:",
      "            if char not in node.children:",
      "                return []",
      "            node = node.children[char]",
      "        return self._collect_words(node, prefix)",
      "",
      "     ",
      "    def _collect_words(self, node, prefix):",
      "        results = []",
      "        if node.is_end:",
      "            results.append(prefix)",
      "",
      "        for char, next_node in node.children.items():",
      "            results.extend(self._collect_words(next_node, prefix + char))",
      "",
      "        return results",
      "",
      "",
      "",
      "def main():",
      "    trie = Trie()",
      "",
      "    while True:",
      "        print('\\n====== AUTOCOMPLETE SYSTEM ======')",
      "        print('1. Insert a word')",
      "        print('2. Get suggestions')",
      "        print('3. Exit')",
      "",
      "        choice = input('Enter your choice: ')",
      "",
      "        if choice == '1':",
      "            word = input('Enter word to insert: ').strip()",
      "            trie.insert(word)",
      "            print(f\"✔ '{word}' inserted successfully.\")",
      "",
      "        elif choice == '2':",
      "            prefix = input('Enter prefix: ').strip()",
      "            suggestions = trie.search(prefix)",
      "",
      "            print('\\n--- Suggestions ---')",
      "            if suggestions:",
      "                for i, word in enumerate(suggestions, 1):",
      "                    print(f'{i}. {word}')",
      "            else:",
      "                print('No suggestions found.')",
      "",
      "        elif choice == '3':",
      "            print('Exiting program...')",
      "            break",
      "",
      "        else:",
      "            print('Invalid choice! Try again.')",
      "",
      "",
      "if __name__ == '__main__':",
      "    main()"
    ]
  },
  "Experiment 2": {
    "prefix": "exp2",
    "body": [
      "import heapq",
      "",
      "class Graph:",
      "    def __init__(self):",
      "        self.edges = {}",
      "",
      "    def add_edge(self, u, v, w):",
      "        self.edges.setdefault(u, []).append((v, w))",
      "        self.edges.setdefault(v, []).append((u, w))",
      "",
      "",
      "def dijkstra(graph, start):",
      "    dist = {node: float('inf') for node in graph.edges}",
      "    prev = {node: None for node in graph.edges}",
      "    dist[start] = 0",
      "    pq = [(0, start)]",
      "",
      "    while pq:",
      "        d, u = heapq.heappop(pq)",
      "        for v, w in graph.edges[u]:",
      "            if d + w < dist[v]:",
      "                dist[v] = d + w",
      "                prev[v] = u",
      "                heapq.heappush(pq, (dist[v], v))",
      "    return dist, prev",
      "",
      "",
      "def shortest_route(graph, start, end):",
      "    dist, prev = dijkstra(graph, start)",
      "    path = []",
      "    while end:",
      "        path.append(end)",
      "        end = prev[end]",
      "    return path[::-1], dist[path[0]]",
      "",
      "",
      "# Main",
      "g = Graph()",
      "n = int(input('Locations: '))",
      "for _ in range(n):",
      "    g.edges[input()] = []",
      "",
      "e = int(input('Paths: '))",
      "for _ in range(e):",
      "    u, v, w = input().split()",
      "    g.add_edge(u, v, int(w))",
      "",
      "start = input('Start: ')",
      "end = input('End: ')",
      "",
      "route, time = shortest_route(g, start, end)",
      "print('Route:', ' -> '.join(route))",
      "print('Travel time:', time)"
    ]
  },
  "Experiment 3": {
    "prefix": "exp3",
    "body": [
      "class DisjointSet:",
      "    def __init__(self, vertices):",
      "        self.parent = {v: v for v in vertices}",
      "        self.rank = {v: 0 for v in vertices}",
      "",
      "    def find(self, v):",
      "        if self.parent[v] != v:",
      "            self.parent[v] = self.find(self.parent[v])",
      "        return self.parent[v]",
      "",
      "    def union(self, u, v):",
      "        ru, rv = self.find(u), self.find(v)",
      "        if ru != rv:",
      "            if self.rank[ru] > self.rank[rv]:",
      "                self.parent[rv] = ru",
      "            else:",
      "                self.parent[ru] = rv",
      "                if self.rank[ru] == self.rank[rv]:",
      "                    self.rank[rv] += 1",
      "",
      "",
      "def kruskal(vertices, edges):",
      "    ds = DisjointSet(vertices)",
      "    mst = []",
      "    edges.sort(key=lambda x: x[2])",
      "",
      "    for u, v, w in edges:",
      "        if ds.find(u) != ds.find(v):",
      "            ds.union(u, v)",
      "            mst.append((u, v, w))",
      "    return mst",
      "",
      "",
      "",
      "vertices = input('Cities: ').split()",
      "e = int(input('Connections: '))",
      "",
      "edges = []",
      "for _ in range(e):",
      "    u, v, w = input().split()",
      "    edges.append((u, v, int(w)))",
      "",
      "mst = kruskal(vertices, edges)",
      "",
      "print('MST Edges:')",
      "for u, v, w in mst:",
      "    print(f'{u} - {v}: {w}')"
    ]
  },
